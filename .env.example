# Local development database (Docker Compose)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/DB_NAME"

# Auth.js v5 — generate secret: openssl rand -base64 32
# Google credentials: console.cloud.google.com → APIs & Services → Credentials
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# AUTH_URL=https://yourdomain.com  # required in production